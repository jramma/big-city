---
interface Props {
  post: any;
}
const { post } = Astro.props;
const hero = post?.data?.heroImage as string;
const basePath = hero
  ? `/assets${hero.startsWith("/") ? hero : `/${hero}`}`
  : "";
const widths = [320, 480, 640, 768, 960];
const quality = 60;
const srcset = basePath
  ? widths
      .map((w) => `${basePath}?nf_resize=fit&w=${w}&q=${quality} ${w}w`)
      .join(", ")
  : "";
const sizes = "(max-width: 768px) 100vw, 50vw";
import FormattedDate from "@/components/FormattedDate.astro";
import { Picture } from "astro:assets";
---

<a
  href={`/blog/${post.id}/`}
  class="relative gap-2 grid md:grid-cols-2 items-start"
>
  {
    hero && (
      <Picture
        src={basePath}
        srcset={srcset}
        sizes={sizes}
        alt={post.data.title}
        width="640"
        height="480"
        class="miniature object-cover "
        loading="lazy"
        decoding="async"
        quality={20}
      />
    )
  }
  <div class="flex flex-col col-span-1 md:pr-6">
    <p>{post.data.title}</p>
    <p class="font-bold text-xl">{post.data.description}</p>
    <div class="flex items-center">
      <FormattedDate date={new Date(post.data.pubDate)} /><span
        class="w-5 text-5xl -mb-7 ml-2">&dot;</span
      >
      <p>4 min read</p>
    </div>
    <p></p>
  </div>
</a>
